{
  "name": "@inkdropapp/base-ui-theme",
  "version": "0.6.0",
  "author": "Takuya Matsuyama<t@inkdrop.app>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inkdropapp/base-ui-theme.git"
  },
  "devDependencies": {
    "@inkdropapp/css": "^0.6.3",
    "@types/node": "^25.5.0",
    "del": "^8.0.1",
    "less": "^4.6.4",
    "mkdirp": "^3.0.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.2"
  },
  "browserslist": [
    "Electron 39.4.0"
  ],
  "description": "Base UI Theme for Inkdrop",
  "files": [
    "styles/theme.css",
    "lib/variable-names.json"
  ],
  "keywords": [
    "inkdrop",
    "markdown"
  ],
  "license": "MIT",
  "scripts": {
    "clean": "rm -rf ./styles",
    "watch": "./scripts/watch.sh",
    "unwatch": "./scripts/unwatch.sh",
    "build": "mkdir -p ./styles && lessc src/semantic.less > styles/theme.css",
    "format": "prettier --write src",
    "generate-variable-names": "mkdir -p ./lib && node --experimental-strip-types ./scripts/generate-variable-names.ts",
    "prepublishOnly": "npm run build && npm run generate-variable-names"
  }
}
